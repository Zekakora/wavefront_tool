QMainWindow {
    background: #f4f7fb;
}
QWidget {
    font-family: "Microsoft YaHei", "Segoe UI", sans-serif;
    font-size: 9pt;
    color: #1f2937;
}
QFrame#framePlotContainer,
QFrame#frameInputConfig,
QFrame#frameResultCard,
QFrame#frameAlgorithmCard,
QWidget#widgetRightPanel {
    background: #ffffff;
    border: 1px solid #dbe3ef;
    border-radius: 12px;
}
QFrame#framePlotContainer {
    background: #fcfdff;
}
QLabel#labelInputSectionTitle,
QLabel#labelResultSectionTitle,
QLabel#labelAlgorithmSectionTitle {
    font-size: 11pt;
    font-weight: 700;
    color: #0f172a;
    padding-bottom: 2px;
}
QLabel#valueCurrentFile,
QLabel#valueCurrentAlgorithm,
QLabel#valueChannelAResult,
QLabel#valueChannelBResult,
QLabel#valueTimeDifference,
QLabel#valueDetectionStatus {
    color: #334155;
    background: #f8fafc;
    border: 1px solid #e5edf6;
    border-radius: 8px;
    padding: 6px 8px;
}
QLineEdit, QComboBox {
    min-height: 34px;
    padding: 4px 10px;
    background: #ffffff;
    border: 1px solid #cfd8e3;
    border-radius: 8px;
}
QLineEdit:focus, QComboBox:focus {
    border: 1px solid #3b82f6;
}
QPushButton {
    min-height: 36px;
    padding: 0 14px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
}
QPushButton:hover {
    background: #1d4ed8;
}
QPushButton#btnClearResult,
QPushButton#btnSaveResult,
QPushButton#btnOpenRdpLocalAicParamDialog,
QPushButton#btnOpenIceemdanTeoParamDialog {
    background: #eef4ff;
    color: #1d4ed8;
    border: 1px solid #c8dafc;
}
QPushButton#btnClearResult:hover,
QPushButton#btnSaveResult:hover,
QPushButton#btnOpenRdpLocalAicParamDialog:hover,
QPushButton#btnOpenIceemdanTeoParamDialog:hover {
    background: #dfeaff;
}
QToolButton {
    min-width: 34px;
    max-width: 34px;
    min-height: 34px;
    background: #eef4ff;
    color: #1d4ed8;
    border: 1px solid #c8dafc;
    border-radius: 8px;
    font-weight: 700;
}
QToolButton:hover {
    background: #dfeaff;
}
QMenuBar {
    background: #ffffff;
    border-bottom: 1px solid #dbe3ef;
}
QToolBar {
    background: #ffffff;
    border-bottom: 1px solid #e5edf6;
    spacing: 6px;
}
QStackedWidget {
    background: transparent;
}
QLabel {
    color: #334155;
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}
QComboBox::down-arrow {
    image: none;
}
</string>
